# ============================================================
#  EquipLink – Root Git Ignore Rules
# ============================================================

# ---- IDE & System ----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ---- Frontend (Next.js) ----
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.turbo/

# ---- Backend (Spring Boot / Maven) ----
backend/target/
backend/out/
backend/*.class
backend/*.log
backend/*.jar
backend/*.war
backend/*.zip
backend/*.tar.gz
backend/.classpath
backend/.project
backend/.settings/
backend/.factorypath
backend/uploads/

# ---- Database & Local Environments ----
.env
docker-compose.override.yml
postgres-data/
*.db
